// prisma/schema.prisma
//
// FIXES IN THIS VERSION
// =====================
//
// 1. MISSING DATABASE INDEXES (CRITICAL)
//    None of the models had any indexes. Every query that filters/sorts by
//    seriesId, albumId, isActive, episodeNumber, or trackNumber was doing a
//    full table scan. With 11+ albums and N songs each, this compounds on
//    every startup request.
//
//    Added indexes for:
//      - Episode: [seriesId, isActive, episodeNumber] — covers the common
//        "get active episodes for a series, ordered by number" query
//      - Song: [albumId, isActive, trackNumber] — covers "get active songs
//        for an album, ordered by track" query
//      - Series/Album: [isActive, createdAt] — covers the list endpoints
//        that filter isActive=true and order by createdAt desc
//      - SyncState: key is already @id (primary key) — no change needed

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Series {
  id                  String    @id @default(uuid())
  title               String
  description         String?
  coverTelegramFileId String?
  isActive            Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  episodes            Episode[]

  // FIX: Index for GET /api/series (filter isActive, order by createdAt)
  @@index([isActive, createdAt(sort: Desc)])
  @@map("series")
}

model Episode {
  id             String   @id @default(uuid())
  seriesId       String
  episodeNumber  Int
  title          String
  description    String?
  telegramFileId String?
  duration       Int?
  partCount      Int      @default(1)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  series         Series   @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  @@unique([seriesId, episodeNumber])
  // FIX: Index for GET /api/series/:id/episodes
  // Covers: WHERE seriesId=? AND isActive=true ORDER BY episodeNumber ASC
  @@index([seriesId, isActive, episodeNumber])
  @@map("episodes")
}

model Album {
  id                  String   @id @default(uuid())
  title               String
  artist              String?
  genre               String?
  releaseYear         Int?
  description         String?
  coverTelegramFileId String?
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  songs               Song[]

  // FIX: Index for GET /api/albums (filter isActive, order by createdAt)
  @@index([isActive, createdAt(sort: Desc)])
  @@map("albums")
}

model Song {
  id             String   @id @default(uuid())
  albumId        String
  trackNumber    Int
  title          String
  artist         String?
  telegramFileId String?
  duration       Int?
  partCount      Int      @default(1)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  album          Album    @relation(fields: [albumId], references: [id], onDelete: Cascade)

  // FIX: Index for GET /api/albums/:id/songs
  // Covers: WHERE albumId=? AND isActive=true ORDER BY trackNumber ASC
  @@index([albumId, isActive, trackNumber])
  // FIX: Index for sync.js deduplication queries (groupBy albumId, findMany by albumId)
  @@index([albumId])
  @@map("songs")
}

// Persists sync cursor across Render deploys (filesystem resets on each deploy).
model SyncState {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("sync_state")
}
