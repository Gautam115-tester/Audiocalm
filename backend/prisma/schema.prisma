generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Series {
  id                  String    @id @default(uuid())
  title               String
  description         String?
  coverTelegramFileId String?
  isActive            Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  episodes            Episode[]

  @@map("series")
}

model Episode {
  id             String   @id @default(uuid())
  seriesId       String
  episodeNumber  Int
  title          String
  telegramFileId String?
  duration       Int?
  partCount      Int      @default(1)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  series         Series   @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  @@unique([seriesId, episodeNumber])
  @@map("episodes")
}

model Album {
  id                  String   @id @default(uuid())
  title               String
  artist              String?
  coverTelegramFileId String?
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  songs               Song[]

  @@map("albums")
}

model Song {
  id             String   @id @default(uuid())
  albumId        String
  trackNumber    Int
  title          String
  telegramFileId String?
  duration       Int?
  partCount      Int      @default(1)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  album          Album    @relation(fields: [albumId], references: [id], onDelete: Cascade)

  // NOTE: @@unique([albumId, trackNumber]) was removed.
  // That constraint caused silent data loss via skipDuplicates when two songs
  // in the same album had colliding TR## track numbers during sync.
  // Deduplication is handled in sync.js via telegramFileId + title checks.
  @@map("songs")
}

// Replaces the ephemeral .sync_state.json file.
// Render resets the filesystem on every deploy — state must live in the DB.
model SyncState {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("sync_state")
}
