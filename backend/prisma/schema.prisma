generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Series {
  id                  String    @id @default(uuid())
  title               String
  description         String?
  coverTelegramFileId String?
  isActive            Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  episodes            Episode[]

  @@map("series")
}

model Episode {
  id             String   @id @default(uuid())
  seriesId       String
  episodeNumber  Int
  title          String
  description    String?
  telegramFileId String?
  duration       Int?
  partCount      Int      @default(1)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  series         Series   @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  @@unique([seriesId, episodeNumber])
  @@map("episodes")
}

model Album {
  id                  String   @id @default(uuid())
  title               String
  artist              String?
  genre               String?
  releaseYear         Int?
  description         String?
  coverTelegramFileId String?
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  songs               Song[]

  @@map("albums")
}

model Song {
  id             String   @id @default(uuid())
  albumId        String
  trackNumber    Int
  title          String
  artist         String?
  telegramFileId String?
  duration       Int?
  partCount      Int      @default(1)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  album          Album    @relation(fields: [albumId], references: [id], onDelete: Cascade)

  // Deduplication handled in sync.js — no unique constraint on trackNumber
  // to prevent silent data loss via skipDuplicates on track number collisions.
  @@map("songs")
}

// Persists sync cursor across Render deploys (filesystem resets on each deploy).
model SyncState {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("sync_state")
}
