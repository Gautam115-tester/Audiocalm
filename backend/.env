# ─────────────────────────────────────────────────────
# AudioVault Backend — Environment Variables
# Copy this to .env and fill in real values
# ─────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database (Supabase PostgreSQL) ────────────────────
# Get from: https://supabase.com → Project Settings → Database → Connection String (URI)
DATABASE_URL="postgresql://postgres.hisitpzleqruhfyhbbzd:8108006068Gm@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?sslmode=require"

DIRECT_URL="postgresql://postgres.hisitpzleqruhfyhbbzd:8108006068@Gm@aws-0-ap-south-1.pooler.supabase.com:5432/postgres?sslmode=require"

# ── Telegram ──────────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN="8700666110:AAHvk5t4BNw20Ee4R_1TU5JIvEd0aNxjfew"

# Channel IDs (with negative sign for channels, e.g. -1001234567890)
# Channel for Audio Stories (files named *_EP*.m4a)
TELEGRAM_STORIES_CHANNEL_ID="-1003504203408"

# Channel for Music (files named *_TR*.m4a)
TELEGRAM_MUSIC_CHANNEL_ID="-1003786059833"

# ── Security ─────────────────────────────────────────
# Random 32+ char secret for internal API calls
API_SECRET_KEY="This is an Demo version"

# ── Cache ─────────────────────────────────────────────
# How long to cache Telegram file URLs (seconds)
# Telegram URLs expire after ~1 hour so keep this under 3000
CACHE_TTL_SECONDS=3000

# ── CORS ──────────────────────────────────────────────
# Comma-separated allowed origins (leave * for dev, restrict in production)
ALLOWED_ORIGINS="*"

# ── Rate Limiting ─────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
