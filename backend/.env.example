# ─── Copy this file to .env and fill in your values ─────────────────────────
# NEVER commit .env to git

# ─── Telegram ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ

# Channel IDs (always negative numbers for channels)
TELEGRAM_STORIES_CHANNEL_ID=-1001234567890
TELEGRAM_MUSIC_CHANNEL_ID=-1009876543210
TELEGRAM_COVERS_CHANNEL_ID=-1001122334455

# ─── Database (PostgreSQL via Supabase / Railway / Render) ───────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
